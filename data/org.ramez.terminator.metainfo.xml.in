<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>org.ramez.terminator</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Terminator</name>
  <summary>Unified manager for installed applications</summary>
  <description>
    <p>
      Terminator is a GTK4 and libadwaita application that lists installed
      apps from multiple Linux packaging systems in a single interface and
      lets you uninstall any of them.
    </p>
    <p>Supported package types:</p>
    <ul>
      <li>System packages (via PackageKit)</li>
      <li>Flatpak applications</li>
      <li>Snap packages</li>
      <li>AppImage launchers</li>
      <li>User-local desktop entries</li>
    </ul>
  </description>

  <developer id="com.github.r6mez">
    <name>Ramez Medhat</name>
  </developer>

  <url type="homepage">https://github.com/r6mez/Terminator</url>
  <url type="vcs-browser">https://github.com/r6mez/Terminator</url>
  <url type="bugtracker">https://github.com/r6mez/Terminator/issues</url>
  <url type="donation">https://github.com/sponsors/r6mez</url>
  <url type="contribute">https://github.com/r6mez/Terminator</url>

  <translation type="gettext">terminator</translation>
  <launchable type="desktop-id">org.ramez.terminator.desktop</launchable>
  <content_rating type="oars-1.1" />

  <branding>
    <color type="primary" scheme_preference="light">#3584e4</color>
    <color type="primary" scheme_preference="dark">#1c71d8</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/r6mez/Terminator/master/assets/banner.png</image>
      <caption>Main window listing installed applications</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="0.1.0" date="2026-05-11">
      <description translate="no">
        <p>Initial release.</p>
      </description>
    </release>
  </releases>

</component>
